# Automated Repair Assistance Environment Configuration
# Copy this file to .env and adjust the values as needed

# --- Frontend Environment Variables (Prefix with NEXT_PUBLIC_) ---
# The base URL of the FastAPI backend for the Next.js app to communicate with.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend Environment Variables ---
# Redis broker URL for Celery task queuing
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis backend URL for Celery task results
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# PostgreSQL database connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://user:password@localhost:5432/repair_db

# (Optional) Add your third-party API keys below (e.g. Gemini API for AI-assisted diagnostics)
GEMINI_API_KEY= "AIzaSyC4XJZT68JHbSSzelFc7BxaD0qvK2wos7k"
